# Versiones para instalación de Synthetic PoP
# Completar antes de ejecutar el procedimiento.

# Ejemplo de formato k3s: v1.xx.x+k3s1
K3S_VERSION="<definir_version_k3s_validada>"

# Ejemplo de formato Helm: v3.xx.x
HELM_VERSION="<definir_version_helm_validada>"

# Versión del chart synthetic-pop obtenida con:
# helm search repo instana/synthetic-pop --versions
POP_CHART_VERSION="<definir_version_chart_synthetic_pop>"

# Namespace y release sugeridos
POP_NAMESPACE="synthetic-pop"
POP_RELEASE="synthetic-pop"
